# Enable assisted contracts against a local pyvisa-tester TCPIP stack.
PYVISA_TESTER_ASSISTED=1

# Optional: point to a dedicated env file consumed by shared profile loader.
# PYVISA_TESTER_ENV_FILE=.env.pyvisa-tester

# Resource availability toggles.
PYVISA_TESTER_VXI11=1
PYVISA_TESTER_HISLIP=1
PYVISA_TESTER_SOCKET=1
PYVISA_TESTER_USB=1
PYVISA_TESTER_GPIB=0
PYVISA_TESTER_ASRL=0
PYVISA_TESTER_GPIB_INTFC_QUERY=0

# Resource addresses exposed by pyvisa-tester.
PYVISA_TESTER_VXI11_ADDR=TCPIP::127.0.0.1::inst0::INSTR
PYVISA_TESTER_HISLIP_ADDR=TCPIP::127.0.0.1::hislip0::INSTR
PYVISA_TESTER_SOCKET_ADDR=TCPIP::127.0.0.1::5025::SOCKET
PYVISA_TESTER_USB_INSTR_ADDR=USB0::0xF4EC::0xEE3A::PYVISA0001::INSTR
PYVISA_TESTER_GPIB_INSTR_ADDR=GPIB0::1::INSTR
PYVISA_TESTER_GPIB_INTFC_ADDR=GPIB0::INTFC
PYVISA_TESTER_ASRL_INSTR_ADDR=ASRL1::INSTR

# Staged binary-transfer and error-query commands exposed by pyvisa-tester.
PYVISA_TESTER_CMD_ERROR_QUERY=SYST:ERR?
PYVISA_TESTER_CMD_BINARY_CONFIGURE_TEMPLATE=DATA:BIN:CFG {datatype},{count},{endian},{header},{termination},{pattern},{start}
PYVISA_TESTER_CMD_BINARY_READ_QUERY=DATA:BIN:READ?

# Expected *IDN? answer from the simulated instrument.
PYVISA_TESTER_EXPECTED_IDN=Cyberdyne systems,T800 Model 101,A9012.C,V2.4
